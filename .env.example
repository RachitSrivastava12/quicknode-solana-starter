# ─────────────────────────────────────────────────────────────
# @quicknode/solana-kit — Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# ── Required ──────────────────────────────────────────────────
# Your QuickNode Solana endpoint URL.
# Get one free at: https://dashboard.quicknode.com
# Looks like: https://your-name.solana-mainnet.quiknode.pro/TOKEN/
QN_ENDPOINT_URL=https://your-endpoint.solana-devnet.quiknode.pro/YOUR_TOKEN/

# ── For transaction + swap examples ───────────────────────────
# Base58-encoded private key of the wallet that will sign + pay.
# Use a TEST wallet with small amounts only.
WALLET_PRIVATE_KEY=your_base58_private_key_here

# ── For NFT + streaming examples ──────────────────────────────
# A Solana wallet address to query NFTs / watch for updates.
WALLET_ADDRESS=your_wallet_public_key_here

# ── Optional: tell the SDK which add-ons you've enabled ───────
# Set to 'true' if you've enabled these on your QuickNode endpoint.
# The SDK works WITHOUT these — it just disables those features
# and shows you a helpful message explaining how to enable them.
ADDON_PRIORITY_FEES=false
ADDON_LILJIT=false
ADDON_DAS=false
ADDON_METIS=false
ADDON_YELLOWSTONE=false

# ── Swap example safety flag ──────────────────────────────────
# Set to 'true' only when you want to actually execute a real swap.
# Default is false — shows quote only, spends nothing.
EXECUTE_SWAP=false
